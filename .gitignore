# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# pipeline data (research output, staged positions, reports)
/data/research-output/
/data/staged-positions/
/data/source-verification-report.json
/data/candidate-manifest.csv
/data/fec-to-bioguide.json
/scripts/.research-cache/

# Claude Code workspace (local agent state, worktrees)
.claude/

# Supabase CLI local cache (project ref, version files, etc.)
/supabase/.temp/
/supabase/.branches/
