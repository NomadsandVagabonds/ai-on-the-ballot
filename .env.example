# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ZIP-code lookup (ZIP → state + congressional district)
# Google Civic Information API's representativeInfoByAddress endpoint was
# deprecated on 2025-04-30, so we use Geocodio instead. Free tier is
# 2,500 lookups/day.
# Sign up: https://dash.geocod.io/register
# Get key: https://dash.geocod.io/apikey
GEOCODIO_API_KEY=your-geocodio-api-key

# ISR Revalidation Secret (for on-demand revalidation webhook)
REVALIDATION_SECRET=your-revalidation-secret

# Site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Pipeline API Keys (for data collection scripts) ---

# FEC API (free — request at https://api.open.fec.gov)
FEC_API_KEY=your-fec-api-key

# Congress.gov API (free — request at https://api.congress.gov)
CONGRESS_API_KEY=your-congress-api-key

# Anthropic API (for AI-assisted stance coding)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Web Search (one of the following):
# Google Custom Search API
GOOGLE_SEARCH_API_KEY=your-google-search-api-key
GOOGLE_SEARCH_CX=your-google-search-cx
# OR SerpAPI
SERPAPI_KEY=your-serpapi-key
